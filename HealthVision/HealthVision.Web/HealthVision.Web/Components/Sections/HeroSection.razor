<section class="hv-hero">

    <div class="hv-hero-bg-grid"></div>
    <div class="hv-hero-bg-orb"></div>

    <div class="hv-hero-inner">

        <!-- Left: headline + CTA -->
        <div class="hv-hero-left">

            <div class="hv-badge">
                <span class="hv-badge-dot"></span>
                AI-powered anatomy platform
            </div>

            <h1 class="hv-hero-title">
                See the body.<br />
                Understand <span class="hv-hero-accent">everything.</span>
            </h1>

            <p class="hv-hero-sub">
                Interactive 3D anatomy with an AI teacher that explains, adapts,
                and guides — from full skeleton to cellular detail. Built for
                medical students, professionals, and the curious.
            </p>

            <div class="hv-hero-btns">
                <a href="#" class="hv-btn hv-btn-primary hv-btn-lg">
                    Explore for free
                </a>
                <a href="#" class="hv-btn hv-btn-secondary hv-btn-lg">
                    ▶&nbsp; Watch demo
                </a>
            </div>

            <div class="hv-hero-stats">
                <div class="hv-hero-stat">
                    <span class="hv-hero-stat-n">50+</span>
                    <span class="hv-hero-stat-l">Body systems</span>
                </div>
                <div class="hv-hero-stat-divider"></div>
                <div class="hv-hero-stat">
                    <span class="hv-hero-stat-n">3</span>
                    <span class="hv-hero-stat-l">Detail levels</span>
                </div>
                <div class="hv-hero-stat-divider"></div>
                <div class="hv-hero-stat">
                    <span class="hv-hero-stat-n">AI</span>
                    <span class="hv-hero-stat-l">Instant answers</span>
                </div>
                <div class="hv-hero-stat-divider"></div>
                <div class="hv-hero-stat">
                    <span class="hv-hero-stat-n">Free</span>
                    <span class="hv-hero-stat-l">To start</span>
                </div>
            </div>

        </div>

        <!-- Right: AI chat mockup -->
        <div class="hv-hero-right">
            <div class="hv-chat-card">

                <div class="hv-chat-header">
                    <span class="hv-chat-status-dot"></span>
                    <span class="hv-chat-title">Dynamic Medical Technologies</span>
                    <span class="hv-chat-online">Online</span>
                </div>

                <div class="hv-chat-body">

                    <div class="hv-msg hv-msg-user">
                        Why does the heart have four chambers?
                    </div>

                    <div class="hv-msg hv-msg-ai">
                        <strong>Great question.</strong> The four-chamber design
                        separates oxygen-rich and oxygen-poor blood into two
                        isolated circuits — pulmonary (lungs) and systemic (body).<br /><br />
                        Without this separation, oxygenated and deoxygenated blood
                        would mix, making circulation far less efficient.
                        <div class="hv-chat-pill">
                            ❤ Heart highlighted in 3D
                        </div>
                    </div>

                    <div class="hv-msg hv-msg-user">
                        Show me what happens during a heart attack
                    </div>

                    <div class="hv-chat-typing">
                        <span></span><span></span><span></span>
                    </div>

                </div>

                <div class="hv-chat-input-row">
                    <div class="hv-chat-input-fake">
                        Ask anything about anatomy...
                    </div>
                    <button class="hv-chat-send" aria-label="Send">↑</button>
                </div>

            </div>
        </div>

    </div>

</section>

